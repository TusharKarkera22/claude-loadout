{
  "name": "claude-loadout",
  "version": "0.1.1",
  "description": "Claude Loadout — share your Claude Code setup like dotfiles. Bundle and install loadouts of CLAUDE.md, skills, slash commands, and sub-agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "claude-loadout": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TusharKarkera22/claude-loadout.git"
  },
  "bugs": {
    "url": "https://github.com/TusharKarkera22/claude-loadout/issues"
  },
  "homepage": "https://github.com/TusharKarkera22/claude-loadout#readme",
  "dependencies": {
    "fast-glob": "^3.3.2",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "claude-loadout",
    "loadout",
    "dotfiles",
    "ai-coding"
  ]
}
